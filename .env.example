# GitHub Copilot / GitHub Models token（由 deploy.py 自动获取，勿手动填写）
GITHUB_TOKEN=

# Docker 里 Hermes 进程使用的 UID/GID（deploy.py 会自动写入）
HERMES_UID=
HERMES_GID=

# Hermes Dashboard HTTPS 本地端口
HERMES_DASHBOARD_PORT=9119

# Hermes OpenAI-compatible API server
API_SERVER_PORT=8642
API_SERVER_KEY=

# Hermes WebUI HTTPS 本地端口
HERMES_WEBUI_PORT=8787

# 时区
TZ=Asia/Shanghai

# SearXNG Secret（由 deploy.py 自动生成）
SEARXNG_SECRET=
