FROM node:22-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
    && curl -fsSL https://openclaw.ai/install.sh | bash -s -- --no-onboard \
    && rm -rf /usr/local/lib/node_modules/npm \
    && rm -rf /usr/local/lib/node_modules/corepack \
    && rm -rf /usr/local/include/node \
    && rm -rf /var/lib/apt/lists/*

# ── Pre-create /data so the node user can write to it at runtime ──────────────
# Named volumes are owned by root on first creation; setting ownership here
# prevents Permission denied errors when the entrypoint runs mkdir -p /data/...
RUN mkdir -p /data/workspace/skills /data/workspace/memory && chown -R node:node /data

ENV NODE_ENV=production

USER node

# Healthcheck used when running via plain `docker run` (not compose).
# Compose overrides this with its own healthcheck block.
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:18789/healthz').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
